{
    "input_model": {
        "type": "HfModel",
        "model_path": "google-bert/bert-large-uncased-whole-word-masking-finetuned-squad",
        "task": "question-answering",
        "load_kwargs": { "attn_implementation": "eager" },
        "io_config": {
            "input_names": ["input_ids", "attention_mask", "token_type_ids"],
            "input_shapes": [
                [1, 512],
                [1, 512],
                [1, 512]
            ],
            "input_types": ["int64", "int64", "int64"],
            "output_names": [ "start_logits","end_logits" ],
            "output_shapes": [[1, 512], [1, 512]]
        }
    },
    "systems": {
        "local_system": {
            "type": "LocalSystem",
            "accelerators": [
                { "device": "cpu", "execution_providers": [ "CPUExecutionProvider" ] }
            ]
        }
    },
    "data_configs": [
        {
            "name": "quant_data_config",
            "user_script": "squaddataset.py",
            "dataloader_config": {
              "type": "squad_calibration_reader",
              "data_dir": "data/squaddataset/train",
              "batch_size": 1
            }
        }
    ],
    "passes": {
        "conversion": { "type": "OnnxConversion", "target_opset": 17 },
        "qnn_preprocess": {
            "type": "QNNPreprocess",
            "save_as_external_data": true,
            "all_tensors_to_one_file": true
        },
        "quantization": {
            "type": "OnnxStaticQuantization",
            "activation_type": "QUInt16",
            "weight_type": "QUInt8",
            "quant_preprocess": true,
            "save_as_external_data": true,
            "all_tensors_to_one_file": true,
            "calibrate_method": "MinMax",
            "data_config": "quant_data_config"
        },
        "session_params_tuning": { "type": "OrtSessionParamsTuning", "data_config": "quant_data_config" }
    },
    "host": "local_system",
    "target": "local_system",
    "cache_dir": "cache",
    "clean_cache": true,
    "output_dir": "./output"
}
